# Resend API key — required for the /contacto form to actually send email.
# Sign up at https://resend.com, create an API key, paste it here in .env.local.
RESEND_API_KEY=

# Optional. Where contact submissions are delivered. Defaults to cmesaramirez@gmail.com.
CONTACT_TO_EMAIL=

# Optional. The "from" address Resend uses. Must be a verified domain in your Resend
# account. Defaults to "Carmen Mesa <onboarding@resend.dev>" (Resend's sandbox sender,
# only delivers to the account owner — verify a domain for production).
CONTACT_FROM_EMAIL=
